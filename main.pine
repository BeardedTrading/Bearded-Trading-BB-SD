//@version=6
strategy("Bearded Trading BB-SD", overlay=true, max_boxes_count=500, initial_capital=10000, calc_on_every_tick=true)

// ==========================================
// --- SECTION 1: CORE STRATEGY INPUTS ---
// ==========================================
useDynamicSL = input.bool(true, "Use Dynamic Stop Loss (Adaptive Window)", group="⚙️ Core Strategy Inputs")
tickBuffer   = input.int(60, "Stop Loss Placement Outside Zone/Swing (Ticks)", group="⚙️ Core Strategy Inputs")
useDynamicTP = input.bool(true, "Use Dynamic Take Profit (Adaptive Window)", group="⚙️ Core Strategy Inputs")
tpBuffer     = input.int(60, "Take Profit Placement Inside/Beyond Zone (Ticks)", group="⚙️ Core Strategy Inputs")
proximityPct = input.float(5.0, "Active Price Proximity %", group="⚙️ Core Strategy Inputs")
offset       = input.int(100, "Zone Forward Extension (Bars)", group="⚙️ Core Strategy Inputs")

// ==========================================
// --- SECTION 2: BOLLINGER BANDS ENGINE ---
// ==========================================
useBB        = input.bool(false, "Enable BB Volatility Overlay", group="📊 Bollinger Bands Engine")
bbLookback   = input.int(3, "BB Signal Confluence Lookback Window (Bars)", minval=0, group="📊 Bollinger Bands Engine")
bbLength     = input.int(20, "BB Basis Length", minval=1, group="📊 Bollinger Bands Engine")
bbSource     = input.source(close, "BB Source", group="📊 Bollinger Bands Engine")
bbType       = input.string("EMA", "BB Basis Type", options=["SMA", "EMA"], group="📊 Bollinger Bands Engine")
bbStdDev     = input.float(2.0, "BB Standard Deviation", minval=0.001, step=0.1, group="📊 Bollinger Bands Engine")

// ==========================================
// --- SECTION 3: GRAPHIC & STYLE SETTINGS ---
// ==========================================
bullColor = input.color(color.new(color.green, 85), "Demand Zone Background Color", group="🎨 Graphic & Style Customizers")
bearColor = input.color(color.new(color.red, 85), "Supply Zone Background Color", group="🎨 Graphic & Style Customizers")

slColor   = input.color(color.red, "Stop Loss Line Color", group="🎨 Graphic & Style Customizers")
slWidth   = input.int(3, "Stop Loss Line Thickness", minval=1, maxval=10, group="🎨 Graphic & Style Customizers")
slStyleIn = input.string("Solid", "Stop Loss Line Format", options=["Solid", "Dashed", "Dotted"], group="🎨 Graphic & Style Customizers")

tpColor   = input.color(color.green, "Take Profit Line Color", group="🎨 Graphic & Style Customizers")
tpWidth   = input.int(3, "Take Profit Line Thickness", minval=1, maxval=10, group="🎨 Graphic & Style Customizers")
tpStyleIn = input.string("Solid", "Take Profit Line Format", options=["Solid", "Dashed", "Dotted"], group="🎨 Graphic & Style Customizers")

bbBasisColor = input.color(color.gray, "BB Basis Line Color", group="🎨 Graphic & Style Customizers")
bbBasisWidth = input.int(1, "BB Basis Line Thickness", minval=1, maxval=10, group="🎨 Graphic & Style Customizers")
bbBandsColor = input.color(color.blue, "BB Upper/Lower Lines Color", group="🎨 Graphic & Style Customizers")
bbBandsWidth = input.int(1, "BB Upper/Lower Lines Thickness", minval=1, maxval=10, group="🎨 Graphic & Style Customizers")

getLineStyle(styleString) =>
    switch styleString
        "Solid"  => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid

slStyle   = getLineStyle(slStyleIn)
tpStyle   = getLineStyle(tpStyleIn)

// ==========================================
// --- BOLLINGER BANDS ENGINE CALCULATIONS ---
// ==========================================
float bbBasis = na
if bbType == "SMA"
    bbBasis := ta.sma(bbSource, bbLength)
else
    bbBasis := ta.ema(bbSource, bbLength)

float bbDev = ta.stdev(bbSource, bbLength) * bbStdDev
float upperBand = bbBasis + bbDev
float lowerBand = bbBasis - bbDev

plot(useBB ? bbBasis : na, "BB Basis", color=bbBasisColor, linewidth=bbBasisWidth)
plot(useBB ? upperBand : na, "BB Upper", color=bbBandsColor, linewidth=bbBandsWidth)
plot(useBB ? lowerBand : na, "BB Lower", color=bbBandsColor, linewidth=bbBandsWidth)

bool isBarClosed = barstate.isconfirmed 
color orangeOutline = color.new(color.orange, 30)

// --- Arrays for Trackers ---
var box[] demandBoxes = array.new_box()
var box[] supplyBoxes = array.new_box()
var int[] demandCreationBar = array.new_int()
var int[] supplyCreationBar = array.new_int()
var label[] demandTradeLabels = array.new_label()
var label[] supplyTradeLabels = array.new_label()
var int[] demandState = array.new_int()
var int[] supplyState = array.new_int()
var float[] demandMinLow = array.new_float()
var float[] supplyMaxHigh = array.new_float()
var bool[] demandTouched = array.new_bool()
var bool[] supplyTouched = array.new_bool()

// --- Arrays for Price Levels (Stored at Creation) ---
var float[] demandSLPrices = array.new_float()
var float[] supplySLPrices = array.new_float()
var float[] demandTPPrices = array.new_float()
var float[] supplyTPPrices = array.new_float()

// --- Arrays for Active Signal Lines ---
var line[] demandSLLines = array.new_line()
var line[] supplySLLines = array.new_line()
var line[] demandTPLines = array.new_line()
var line[] supplyTPLines = array.new_line()

var int lastDemandBar = na
var int lastSupplyBar = na
var int potentialDemandBaseBar = na
var float potentialDemandBaseHigh = na
var float potentialDemandBaseLow = na
var int potentialSupplyBaseBar = na
var float potentialSupplyBaseHigh = na
var float potentialSupplyBaseLow = na

if close < open
    potentialDemandBaseBar  := bar_index
    potentialDemandBaseHigh := high
    potentialDemandBaseLow  := low

if close > open
    potentialSupplyBaseBar := bar_index
    potentialSupplyBaseHigh := high
    potentialSupplyBaseLow  := low

bool alertBuy  = false
bool alertSell = false

checkOverlap(box[] boxArray, float nTop, float nBot) =>
    bool overlaps = false
    if array.size(boxArray) > 0
        for i = 0 to array.size(boxArray) - 1
            b = array.get(boxArray, i)
            if (nTop >= box.get_bottom(b) and nBot <= box.get_top(b))
                overlaps := true
                break
    overlaps

// --- Demand Discovery ---
bool isDemandTrigger = false
if not na(potentialDemandBaseBar) and bar_index > potentialDemandBaseBar
    if high > potentialDemandBaseHigh
        isDemandTrigger := true

if isDemandTrigger and not checkOverlap(demandBoxes, potentialDemandBaseHigh, potentialDemandBaseLow)
    int currentBaseBar = potentialDemandBaseBar
    box newBox = box.new(currentBaseBar, potentialDemandBaseHigh, bar_index + offset, potentialDemandBaseLow, bgcolor=bullColor, border_color=orangeOutline, border_style=line.style_solid, border_width=1)
    array.push(demandBoxes, newBox)
    array.push(demandCreationBar, bar_index)
    array.push(demandTradeLabels, na)
    array.push(demandState, 0)
    array.push(demandTouched, false)
    array.push(demandMinLow, high)
    array.push(demandSLLines, na)
    array.push(demandTPLines, na)
    
    // Initial SL/TP (Will be updated at signal candle relative to Low/High)
    array.push(demandSLPrices, 0.0)
    array.push(demandTPPrices, 0.0)
    
    lastDemandBar := currentBaseBar
    potentialDemandBaseBar := na

// --- Supply Discovery ---
bool isSupplyTrigger = false
if not na(potentialSupplyBaseBar) and bar_index > potentialSupplyBaseBar
    if low < potentialSupplyBaseLow
        isSupplyTrigger := true

if isSupplyTrigger and not checkOverlap(supplyBoxes, potentialSupplyBaseHigh, potentialSupplyBaseLow)
    int currentBaseBar = potentialSupplyBaseBar
    box newBox = box.new(currentBaseBar, potentialSupplyBaseHigh, bar_index + offset, potentialSupplyBaseLow, bgcolor=bearColor, border_color=orangeOutline, border_style=line.style_solid, border_width=1)
    array.push(supplyBoxes, newBox)
    array.push(supplyCreationBar, bar_index)
    array.push(supplyTradeLabels, na)
    array.push(supplyState, 0)
    array.push(supplyTouched, false)
    array.push(supplyMaxHigh, low)
    array.push(supplySLLines, na)
    array.push(supplyTPLines, na)

    // Initial SL/TP (Will be updated at signal candle relative to High/Low)
    array.push(supplySLPrices, 0.0)
    array.push(supplyTPPrices, 0.0)

    lastSupplyBar := currentBaseBar
    potentialSupplyBaseBar := na

float upLimit = close * (1 + (proximityPct / 100))
float loLimit = close * (1 - (proximityPct / 100))

// --- Demand Management ---
if array.size(demandBoxes) > 0
    for i = array.size(demandBoxes) - 1 to 0
        b = array.get(demandBoxes, i), bTop = box.get_top(b), bBot = box.get_bottom(b)
        cBar = array.get(demandCreationBar, i), currentState = array.get(demandState, i)
        tLbl = array.get(demandTradeLabels, i), dTouched = array.get(demandTouched, i)
        slL = array.get(demandSLLines, i), tpL = array.get(demandTPLines, i)
        
        if bar_index > cBar + 1
            if low < array.get(demandMinLow, i)
                array.set(demandMinLow, i, low)
            if not dTouched and (low <= bTop and high >= bBot)
                dTouched := true
                array.set(demandTouched, i, true)
            if (currentState == 0 or currentState == 3) and (close > bTop or low > bTop)
                currentState := 1
            if currentState == 1 and low <= bTop and high >= bBot
                currentState := 2
            array.set(demandState, i, currentState)
        
        if (close < bBot) or bBot > upLimit or bTop < loLimit
            box.delete(b)
            if not na(tLbl) 
                label.delete(tLbl)
            if not na(slL) 
                line.delete(slL)
            if not na(tpL) 
                line.delete(tpL)
            array.remove(demandBoxes, i), array.remove(demandCreationBar, i), array.remove(demandTradeLabels, i), array.remove(demandState, i)
            array.remove(demandTouched, i), array.remove(demandMinLow, i), array.remove(demandSLPrices, i), array.remove(demandTPPrices, i)
            array.remove(demandSLLines, i), array.remove(demandTPLines, i)
        else
            if currentState == 2 and bar_index > cBar + 1 and dTouched
                if (close > open) and (close > bTop) and (close[1] > bBot)
                    array.set(demandState, i, 3), alertBuy := true
                    
                    // --- Risk Management anchored to Signal Candle Low/High ---
                    float slPrice = low - (syminfo.mintick * tickBuffer)
                    float tpPrice = high + (syminfo.mintick * tpBuffer)

                    if useDynamicSL and not na(lastDemandBar)
                        int lookback = bar_index - lastDemandBar
                        if lookback > 2
                            float structLow = na
                            for j = 1 to lookback - 1
                                if low[j] <= low[j+1] and low[j] <= low[j-1]
                                    if na(structLow) or low[j] < structLow
                                        structLow := low[j]
                            if not na(structLow) and structLow < low
                                slPrice := structLow - (syminfo.mintick * tickBuffer)
                    
                    if useDynamicTP and not na(lastDemandBar)
                        int tpLookback = bar_index - lastDemandBar
                        if tpLookback > 2
                            float structHigh = na
                            for j = 1 to tpLookback - 1
                                if high[j] >= high[j+1] and high[j] >= high[j-1]
                                    if na(structHigh) or high[j] > structHigh
                                        structHigh := high[j]
                            if not na(structHigh) and structHigh > high
                                tpPrice := structHigh + (syminfo.mintick * tpBuffer)
                    
                    array.set(demandSLPrices, i, slPrice)
                    array.set(demandTPPrices, i, tpPrice)
                    
                    if isBarClosed
                        strategy.entry("Long", strategy.long), strategy.exit("X Long", "Long", stop=slPrice, limit=tpPrice)
                        if not na(slL) 
                            line.delete(slL)
                        if not na(tpL) 
                            line.delete(tpL)
                        newSL = line.new(bar_index, slPrice, bar_index + 5, slPrice, color=slColor, width=slWidth, style=slStyle)
                        newTP = line.new(bar_index, tpPrice, bar_index + 5, tpPrice, color=tpColor, width=tpWidth, style=tpStyle)
                        array.set(demandSLLines, i, newSL)
                        array.set(demandTPLines, i, newTP)

                    box.set_border_color(b, color.new(color.green, 40)), box.set_border_width(b, 1)
                    
                    bool lowerBB = false, bool upperEx = false
                    if useBB
                        for j = 0 to bbLookback
                            if low[j] <= lowerBand[j] 
                                lowerBB := true
                            if high[j] >= upperBand[j] 
                                upperEx := true
                    
                    emaUp = useBB and (bbBasis > bbBasis[1]), lStr = "BUY", lCol = #a0c4ff
                    if useBB and not upperEx
                        if lowerBB and emaUp 
                            lStr := "BUY A++", lCol := #0052cc
                        else if lowerBB 
                            lStr := "BUY A+", lCol := #3a86ff
                    
                    newLabel = label.new(bar_index, low, text=lStr, style=label.style_triangleup, color=lCol, textcolor=lCol, size=size.small, yloc=yloc.belowbar, text_formatting=text.format_bold)
                    if not na(tLbl) 
                        label.delete(tLbl)
                    array.set(demandTradeLabels, i, newLabel)
            box.set_right(b, bar_index + offset)

// --- Supply Management ---
if array.size(supplyBoxes) > 0
    for i = array.size(supplyBoxes) - 1 to 0
        b = array.get(supplyBoxes, i), bTop = box.get_top(b), bBot = box.get_bottom(b)
        cBar = array.get(supplyCreationBar, i), currentState = array.get(supplyState, i)
        tLbl = array.get(supplyTradeLabels, i), sTouched = array.get(supplyTouched, i)
        slL = array.get(supplySLLines, i), tpL = array.get(supplyTPLines, i)
        
        if bar_index > cBar + 1
            if high > array.get(supplyMaxHigh, i)
                array.set(supplyMaxHigh, i, high)
            if not sTouched and (high >= bBot and low <= bTop)
                sTouched := true
                array.set(supplyTouched, i, true)
            if (currentState == 0 or currentState == 3) and (close < bBot or high < bBot)
                currentState := 1
            if currentState == 1 and high >= bBot and low <= bTop
                currentState := 2
            array.set(supplyState, i, currentState)
        
        if (close > bTop) or bBot > upLimit or bTop < loLimit
            box.delete(b)
            if not na(tLbl) 
                label.delete(tLbl)
            if not na(slL) 
                line.delete(slL)
            if not na(tpL) 
                line.delete(tpL)
            array.remove(supplyBoxes, i), array.remove(supplyCreationBar, i), array.remove(supplyTradeLabels, i), array.remove(supplyState, i)
            array.remove(supplyTouched, i), array.remove(supplyMaxHigh, i), array.remove(supplySLPrices, i), array.remove(supplyTPPrices, i)
            array.remove(supplySLLines, i), array.remove(supplyTPLines, i)
        else
            if currentState == 2 and bar_index > cBar + 1 and sTouched
                if (close < open) and (close < bBot) and (close[1] < bTop)
                    array.set(supplyState, i, 3), alertSell := true
                    
                    // --- Risk Management anchored to Signal Candle High/Low ---
                    float slPrice = high + (syminfo.mintick * tickBuffer)
                    float tpPrice = low - (syminfo.mintick * tpBuffer)

                    if useDynamicSL and not na(lastSupplyBar)
                        int lookback = bar_index - lastSupplyBar
                        if lookback > 2
                            float structHigh = na
                            for j = 1 to lookback - 1
                                if high[j] >= high[j+1] and high[j] >= high[j-1]
                                    if na(structHigh) or high[j] > structHigh
                                        structHigh := high[j]
                            if not na(structHigh) and structHigh > high
                                slPrice := structHigh + (syminfo.mintick * tickBuffer)

                    if useDynamicTP and not na(lastSupplyBar)
                        int tpLookback = bar_index - lastSupplyBar
                        if tpLookback > 2
                            float structLow = na
                            for j = 1 to tpLookback - 1
                                if low[j] <= low[j+1] and low[j] <= low[j-1]
                                    if na(structLow) or low[j] < structLow
                                        structLow := low[j]
                            if not na(structLow) and structLow < low
                                tpPrice := structLow - (syminfo.mintick * tpBuffer)
                    
                    array.set(supplySLPrices, i, slPrice)
                    array.set(supplyTPPrices, i, tpPrice)
                    
                    if isBarClosed
                        strategy.entry("Short", strategy.short), strategy.exit("X Short", "Short", stop=slPrice, limit=tpPrice)
                        if not na(slL) 
                            line.delete(slL)
                        if not na(tpL) 
                            line.delete(tpL)
                        newSL = line.new(bar_index, slPrice, bar_index + 5, slPrice, color=slColor, width=slWidth, style=slStyle)
                        newTP = line.new(bar_index, tpPrice, bar_index + 5, tpPrice, color=tpColor, width=tpWidth, style=tpStyle)
                        array.set(supplySLLines, i, newSL)
                        array.set(supplyTPLines, i, newTP)

                    box.set_border_color(b, color.new(color.red, 40)), box.set_border_width(b, 1)
                    
                    bool upperBB = false, bool lowerEx = false
                    if useBB
                        for j = 0 to bbLookback
                            if high[j] >= upperBand[j] 
                                upperBB := true
                            if low[j] <= lowerBand[j] 
                                lowerEx := true
                    
                    emaDown = useBB and (bbBasis < bbBasis[1]), lStr = "SELL", lCol = #ffb7b2
                    if useBB and not lowerEx
                        if upperBB and emaDown 
                            lStr := "SELL A++", lCol := #9b0000
                        else if upperBB 
                            lStr := "SELL A+", lCol := #ff3333
                    
                    newLabel = label.new(bar_index, high, text=lStr, style=label.style_triangledown, color=lCol, textcolor=lCol, size=size.small, yloc=yloc.abovebar, text_formatting=text.format_bold)
                    if not na(tLbl) 
                        label.delete(tLbl)
                    array.set(supplyTradeLabels, i, newLabel)
            box.set_right(b, bar_index + offset)

if alertBuy 
    alert("BUY Signal: Demand Zone Retest at " + str.tostring(close), alert.freq_once_per_bar_close)
if alertSell 
    alert("SELL Signal: Supply Zone Retest at " + str.tostring(close), alert.freq_once_per_bar_close)